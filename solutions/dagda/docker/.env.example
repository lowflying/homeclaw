# Dagda environment config
# cp .env.example .env  —  then fill in values
# NEVER commit .env to git

# Your WSL2 user/group ID (run: id -u && id -g)
PUID=1000
PGID=1000

# Timezone
TZ=Europe/Dublin

# Media library root — D:\Media in WSL2
# All arr services mount this same root so hardlinks work across Downloads → library
MEDIA_ROOT=/mnt/d/Media

# Service config storage (relative to docker-compose.yml)
# Lives inside WSL2 virtual disk — fast I/O, gitignored
CONFIG_ROOT=./data

# ── Immich ───────────────────────────────────────────────────────────────────
# Where Immich stores photos it manages (its own upload library)
IMMICH_UPLOAD_LOCATION=/mnt/f/Immich/library

# Postgres credentials — pick anything, used only internally
DB_USERNAME=immich
DB_PASSWORD=changeme_strong_password_here
DB_DATABASE_NAME=immich

# ── Restic backup ─────────────────────────────────────────────────────────────
# Hetzner Object Storage bucket for encrypted offsite backups
RESTIC_REPOSITORY=s3:https://fsn1.your-objectstorage.com/dagda-backup

# Encryption passphrase — store in password manager. If lost, backup is unrecoverable.
RESTIC_PASSWORD="changeme_strong_passphrase_here"

# Dedicated S3 credentials for dagda-backup bucket (separate from Terraform creds)
# Generate at: Hetzner Cloud Console → Object Storage → Access Keys
RESTIC_S3_KEY=your_hetzner_s3_access_key_id
RESTIC_S3_SECRET=your_hetzner_s3_secret_access_key
